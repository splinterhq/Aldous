      "%markov_ev":          { "similarity": { "min": 56, "max": 70 }, "distance": { "max": 40 } }
    },

    "lincoln_gettysburg_hay_copy.txt": {
      "%markov_ev":          { "similarity": { "min": 62, "max": 75 }, "distance": { "max": 40 } },
      "++joy":               { "similarity": { "min": 60, "max": 72 } },
      "%markov_structural":  { "similarity": { "min": 60, "max": 71 } },
      "%markov_partisan":    { "similarity": { "min": 60, "max": 75 } }
    },

    "poe_anabelle_lee.txt": {
      "%markov_ev":          { "similarity": { "min": 58, "max": 70 }, "distance": { "max": 50 } },
      "+spirituality":       { "similarity": { "min": 57, "max": 70 } },
      "+sadness":            { "similarity": { "min": 56, "max": 68 } },
