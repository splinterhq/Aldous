      "+tension":            { "similarity": { "min": 54, "max": 70 } },
      "+sadness":            { "similarity": { "min": 51, "max": 65 } }
    },

    "stackoverflow_bobince_regex_html_parsing.txt": {
      "%markov_ev":          { "similarity": { "min": 46, "max": 60 }, "distance": { "max": 50 } },
      "%markov_structural":  { "similarity": { "min": 46, "max": 58 } },
      "@Reactionary":        { "similarity": { "min": 43, "max": 55 } },
