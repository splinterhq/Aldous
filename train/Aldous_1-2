#!/bin/sh
# Named After Aldous Huxley, who wrote about the dangers of over-reliance on
# partisan and emotional framing in "Brave New World". This classifier is designed to
# capture a wide range of emotionally and ideologically charged language, graduated
# by intensity and scope. It includes categories for tension, anger, fear, sadness, joy,
# hedonism, sexuality, spirituality, conflict, hate, violence, philosophical tension
# and tech existential risk, as well as outlook and partisan framing. Each category is
# graduated from mild/ambient language to personal grievance to collective/systemic levels.
#
# 85% Human-generated phrases
# 15% Synthetic backfill (Sonnet 4.6, Opus 4.8, Gemini 3 Pro)
# Copyright (c) 2024 Tim Post. All rights reserved. See LICENSE for details.
#
# SHUNT BIAS NOTICE
# If a human writes the shunt, the shunt will have the bias of the human.
# If the shunt is synthetic, it will have the bias in the model's training
# If a diverse group of humans writes the shunt, where the most vulnerable are 
# represented, it will be much more effective. Synthetic backfill *from* that as
# needed, but start with a group if you can. Social media works well for this.
#
# Default the model name to the basename of this script ($0) unless an explicit
# name is passed as $1. This lets the model be trained by just running it, only
# needing an argument when doing something other than the default. Declared
# before sourcing model_funcs.sh so the splinterpctl alias bakes in the store.
ALDOUS="${1:-$(basename "$0")}"

. util/lib/model_funcs.sh

mkdir -p "dece/${ALDOUS}"
INIT "dece/${ALDOUS}/${ALDOUS}.dece" 250 8192

# Start the stopwatch: time the full vector-fill span, from the embedder
# coming up through the post-training monolithic shunts at the bottom.
__FILL_START=$(date +%s)

# Bring up the embedding butler so each SENSOR's lua can have its phrases
# embedded live as we provision. Torn down by STOP_EMBEDDER before the shunts.
START_EMBEDDER "dece/${ALDOUS}/${ALDOUS}.dece"

